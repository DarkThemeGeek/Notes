    40                                  ; our data is declared here (the variables needed by our program)
    41                                  segment data use32 class=data
    42                                      ; ...
    43 00000000 0500                        a dw 5
    44 00000002 02                          b db 2
    45                                      
    46                                  ; our code starts here
    47                                  segment code use32 class=code
    48                                  
    49                                      start:
    50 00000000 A1[00000000]                    mov eax,[a]
    51 00000005 8B1D[02000000]                  mov ebx ,[b]
    52 0000000B 39D8                            cmp eax,ebx
    53 0000000D 740A                            jz equal
    54 0000000F EB0E                            jmp not_equal
    55                                          
    56                                          
    57                                          
    58 00000011 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    59 00000013 FF15[00000000]                  call    [exit]       ; call exit to terminate the program
    60                                    equal:
    61 00000019 011D[00000000]                  add [a],ebx
    62                                    not_equal:
    63 0000001F 291D[00000000]                  sub [a],ebx
