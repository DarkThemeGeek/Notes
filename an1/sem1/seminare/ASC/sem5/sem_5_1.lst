    60                                  segment data use32 class=data
    61 00000000 01000000                   c dd 1
    62 00000004 02000000                   b dd 2
    63 00000008 00000000                   a dd 0
    64 0000000C 53756D206F66202564-        message dd "Sum of %d + %d =%d",0
    64 00000015 202B202564203D2564-
    64 0000001E 000000000000       
    65                                  
    66                                     
    67                                      
    68                                  ; 0    
    69                                  ; ----------------------=
    70                                  ; |code|heap ->|<- stack|
    71                                  ; ----------------------=
    72                                  ; our code starts here
    73                                  segment code use32 class=code
    74                                      start:
    75 00000000 A1[00000000]                    mov eax,[c]
    76 00000005 0305[04000000]                  add eax,[b]
    77 0000000B A3[08000000]                    mov [a],eax
    78 00000010 B903000000                      mov ecx,3
    79 00000015 51                              push ecx
    80                                          repeat_1:
    81 00000016 FF35[08000000]                  push dword[a]
    82 0000001C FF35[00000000]                  push dword[c]
    83 00000022 FF35[04000000]                  push dword[b]
    84 00000028 68[0C000000]                    push message
    85 0000002D FF15[00000000]                  call [printf]
    86 00000033 83C410                          add esp,4*4
    87 00000036 59                              pop ecx
    88 00000037 E2DD                            loop repeat_1
    89                                   
    90                                          ; exit(0)
    91 00000039 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    92 0000003B FF15[00000000]                  call    [exit]       ; call exit to terminate the program
