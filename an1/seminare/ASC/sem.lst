     1                                  bits 32 ; assembling for the 32 bits architecture
     2                                  
     3                                  ; declare the EntryPoint (a label defining the very first instruction of the program)
     4                                  global start        
     5                                  
     6                                  ; declare external functions needed by our program
     7                                  extern exit               ; tell nasm that exit exists even if we won't be defining it
     8                                  import exit msvcrt.dll    ; exit is a function that ends the calling process. It is defined in msvcrt.dll
     9                                                            ; msvcrt.dll contains exit, printf and all the other important C-runtime specific functions
    10                                  
    11                                  ; our data is declared here (the variables needed by our program)
    12                                  segment data use32 class=data
    13 00000000 0002                       a dw 512
    14 00000002 0A000000                   b dd 10
    15                                  
    16                                  ; our code starts here
    17                                  segment code use32 class=code
    18                                      start:
    19                                     ; mov eax,0
    20                                     ; mov ax,[-a]
    21                                     ; add eax,[b] unsigned conversions
    22 00000000 66A1[00000000]              mov ax,word[a]
    23                                      
    24 00000006 98                          CWDE;signed conversions
    25                                      ;CBW AL->AX implicit operands
    26                                      ;CWDE AX->EAX
    27                                      ;mov <reg8> <mem8> explicit operands
    28                                      ;CWD AX->DX:AX
    29                                      ;CDQ EAX->EDX:EAX
    30                                      
    31                                      ;MUL op Unsigned
    32                                      ;AL*op=AX
    33                                      ;AX*op=DX:AX
    34                                      ;EAX*op=EDX*EAX
    35                                      ;IMUL signed
    36                                      
    37                                      ;DIV op
    38                                      ;b=> AX/op -AL,AH remainder
    39                                      ;w=> DX:AX/op AX,DX remainder
    40                                      ;d=> EDX:EAX/op EAX,EDX remainder
    41                                      ;IDIV op signed
    42                                      ;ADC /SBB
    43                                      ;x dq 5 y dq 10
    44                                      ;mov eax,[x]
    45                                      ;mov edx
    46                                      
    47                                      ;add eax,[b]
    48 00000007 0500000000000000            x dq 5
    49 0000000F 0A00000000000000            z dq 10
    50 00000017 A1[07000000]                 mov eax,[x]
    51 0000001C 8B15[0B000000]               mov edx,[x+4]
    52 00000022 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    53 00000024 FF15[00000000]                  call    [exit]       ; call exit to terminate the program
